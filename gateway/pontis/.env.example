# ---------------------------------------------------------------------------
# PontisGlobe VPS gateway environment.
# Copy to `.env` on the whitelisted VPS and fill in the real values.
# NEVER commit the real `.env` — only this example is tracked.
# ---------------------------------------------------------------------------

# Port the Express gateway listens on.
PORT=8787

# Shared secret between the Vercel app and this gateway. Must match
# PONTIS_GATEWAY_SECRET set on Vercel. Use a long random string.
INRSETTLE_GATEWAY_SECRET=

# ---------------------------------------------------------------------------
# PontisGlobe API credentials (server-only, VPS-only).
# Sandbox base URL: https://sandbox.pontisglobe.com  (live: https://api.pontisglobe.com)
# ---------------------------------------------------------------------------
PONTIS_BASE_URL=https://sandbox.pontisglobe.com
PONTIS_API_KEY=
# base64url-encoded; MUST decode to exactly 32 bytes (AES-256-GCM key).
PONTIS_ENCRYPTION_SECRET=
# base64url-encoded HMAC-SHA256 key (signs requests).
PONTIS_HMAC_SECRET=
PONTIS_EMAIL=
PONTIS_PASSWORD=
