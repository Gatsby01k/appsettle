# ---------------------------------------------------------------------------
# Core app (required to run INRSettle)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/inrsettle
# Must be at least 32 characters.
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# ---------------------------------------------------------------------------
# Demo surface (local/demo ONLY — never in pilot/production)
# Controls the demo-credentials block on the login page, the demo quote-rate
# fallback, and the gated provider sandbox test routes.
# PILOT/PROD: set NEXT_PUBLIC_DEMO_MODE=false and leave the other two UNSET
# (NEXT_PUBLIC_* values are inlined into the client bundle).
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_DEMO_EMAIL=ops@inrsettle.com
# NEXT_PUBLIC_DEMO_PASSWORD=ChangeMe123!

# ---------------------------------------------------------------------------
# Quote pricing (required in pilot/production)
# Manual desk rate for USDT/INR — there is no live FX feed. Must be a positive
# number. If unset in production (without demo mode), quote creation fails
# closed by design.
# ---------------------------------------------------------------------------
QUOTE_RATE_USDT_INR=83.50

# ---------------------------------------------------------------------------
# SHADOW / LIVE_TEST pilot guardrails (INR amounts; safe defaults in code:
# shadow 10000, live test 1000, daily 2000)
# ---------------------------------------------------------------------------
SHADOW_MAX_INR=10000
LIVE_TEST_MAX_INR=1000
LIVE_TEST_DAILY_MAX_INR=2000
# Comma-separated, case-insensitive provider allowlist for LIVE_TEST.
LIVE_TEST_ALLOWED_PROVIDERS=remitquickly,PontisGlobe

# TRIPWIRE — never set this. Nothing in the codebase reads it as "go live";
# setting it to true only BLOCKS shadow/live-test finality as a safety stop.
# LIVE_PAYOUTS_ENABLED=

# ---------------------------------------------------------------------------
# RemitQuickly sandbox payout provider
# Credentials are server-only and MUST NOT be exposed to the frontend.
# NOTE: The RemitQuickly docs reference `api-test.remitquickly.com` as the
# sandbox host. Set REMITQUICKLY_BASE_URL to whichever sandbox base URL your
# account was issued.
# ---------------------------------------------------------------------------
REMITQUICKLY_BASE_URL=https://sandbox.remitquickly.com/v1
REMITQUICKLY_API_KEY=
REMITQUICKLY_API_SECRET=
# Used to verify inbound payout webhooks. Falls back to REMITQUICKLY_API_SECRET
# (which is what the provider signs payout webhooks with by default).
REMITQUICKLY_WEBHOOK_SECRET=

# Optional: default RemitQuickly quote id used when building a sandbox payout.
# REMITQUICKLY_DEFAULT_QUOTE_ID=1
# Optional: fixed webhook URL registered via /set-webhook (otherwise derived
# from the request origin).
# REMITQUICKLY_WEBHOOK_URL=https://your-app.example.com/api/providers/remitquickly/webhook
# Optional: force-enable the gated sandbox test surface outside demo mode.
# REMITQUICKLY_SANDBOX_TEST=true

# ---------------------------------------------------------------------------
# PontisGlobe VPS gateway (Vercel side)
# PontisGlobe whitelists the VPS static IP, so the Vercel app MUST NOT call
# Pontis directly. Instead it calls the gateway running on the VPS. Only these
# two values belong in the Vercel environment — the Pontis API keys below MUST
# NOT be set on Vercel.
#   POST ${PONTIS_GATEWAY_URL}/pontis/payout
#   POST ${PONTIS_GATEWAY_URL}/pontis/status
# authenticated with the x-inrsettle-gateway-secret header.
# ---------------------------------------------------------------------------
PONTIS_GATEWAY_URL=https://your-vps-host.example.com
# Shared secret between Vercel and the VPS gateway. Use a long random string.
PONTIS_GATEWAY_SECRET=

# ---------------------------------------------------------------------------
# PontisGlobe sandbox API provider (VPS / gateway host ONLY)
# Server-only. These secrets MUST NOT be exposed to the frontend (no
# NEXT_PUBLIC_ prefix) and MUST NOT be set in the Vercel environment — they live
# only on the whitelisted VPS that serves /pontis/payout and /pontis/status.
# Docs: https://docs.pontisglobe.com
# Sandbox base URL: https://sandbox.pontisglobe.com  (live: https://api.pontisglobe.com)
# The gateway also needs PONTIS_GATEWAY_SECRET (above) to authenticate inbound
# requests from the Vercel app.
# ---------------------------------------------------------------------------
PONTIS_BASE_URL=https://sandbox.pontisglobe.com
PONTIS_API_KEY=
# base64url-encoded; MUST decode to exactly 32 bytes (AES-256-GCM key).
PONTIS_ENCRYPTION_SECRET=
# base64url-encoded HMAC-SHA256 key (signs requests + verifies callbacks).
PONTIS_HMAC_SECRET=
PONTIS_EMAIL=
PONTIS_PASSWORD=

# Optional: force-enable the dev-only Pontis test/status routes outside of a
# non-production NODE_ENV (e.g. in a hosted preview environment).
# PONTIS_SANDBOX_TEST=true

